{
  "name": "website-change-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "dev": "tsx src/server/cli.ts start",
    "doctor": "node dist/server/cli.js doctor",
    "doctor:dev": "tsx src/server/cli.ts doctor",
    "configure": "tsx src/server/cli.ts configure",
    "install:chromium": "playwright install chromium",
    "start": "node dist/server/cli.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "@fastify/static": "10.1.0",
    "@fastify/swagger": "9.8.1",
    "better-sqlite3": "12.11.1",
    "fastify": "5.10.0",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
